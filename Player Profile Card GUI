local function closeCard()
	if not card.Visible or ClosingCard then
		return
	end
	ClosingCard = true
	local originalPosition = card.Position
	local swipeTween =
		TweenService:Create(
			card,
			TweenInfo.new(
				0.35,
				Enum.EasingStyle.Quint,
				Enum.EasingDirection.In
			),
			{
				Position =
					originalPosition + UDim2.fromOffset(150,0),

				BackgroundTransparency = 1
			}
		)

	local scaleTween =
		TweenService:Create(
			cardScale,
			TweenInfo.new(
				0.35,
				Enum.EasingStyle.Quint,
				Enum.EasingDirection.In
			),
			{
				Scale = 0.85
			}
		)

	swipeTween:Play()
	scaleTween:Play()

	swipeTween.Completed:Wait()
	card.Visible = false
	card.BackgroundTransparency = CardTransparency
	cardScale.Scale = 1

	ClosingCard = false

end

local currentPlayer
local function updateCard(player)
	if not player.Character then
		return
	end

	local image =
		Players:GetUserThumbnailAsync(
			player.UserId,
			Enum.ThumbnailType.HeadShot,
			Enum.ThumbnailSize.Size150x150
		)

	avatar.Image = image

	local humanoid =
		player.Character:FindFirstChildOfClass("Humanoid")
	    local health = "UNKNOWN"
	 if humanoid then
		health =
	    	math.floor(humanoid.Health)
		    ..
	        "/"
	    	..
			math.floor(humanoid.MaxHealth)
	end
	  local rootPart =
	player.Character:FindFirstChild("HumanoidRootPart")

local distance = "UNKNOWN"
if rootPart and LocalPlayer.Character then
	local localRoot =
		LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
	if localRoot then
		distance =
			math.floor(
				(rootPart.Position - localRoot.Position).Magnitude
			)
			..
			" studs"
	end
end

local location = "UNKNOWN"
if rootPart then
	local pos = rootPart.Position
	location =
		math.floor(pos.X)
		..
		", "
		..
		math.floor(pos.Y)
		..
		", "
		..
		math.floor(pos.Z)
end

text.Text =
